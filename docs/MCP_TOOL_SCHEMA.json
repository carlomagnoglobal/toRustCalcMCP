{
  "protocolVersion": "2025-06-18",
  "serverInfo": {
    "name": "toRustCalcMCP",
    "title": "calc \u2014 arbitrary-precision calculator",
    "version": "0.3.0"
  },
  "capabilities": {
    "tools": {
      "listChanged": false
    }
  },
  "toolsListResult": {
    "tools": [
      {
        "description": "Evaluate an arbitrary-precision calc expression (exact rational arithmetic) and return the result.",
        "inputSchema": {
          "additionalProperties": false,
          "properties": {
            "digits": {
              "description": "Decimal digits in real mode (default 20)",
              "maximum": 10000,
              "minimum": 1,
              "type": "integer"
            },
            "epsilon": {
              "description": "Precision target for irrational results",
              "type": "string"
            },
            "expression": {
              "description": "The expression to evaluate",
              "type": "string"
            },
            "mode": {
              "description": "Output rendering (default: real)",
              "enum": [
                "real",
                "frac",
                "int"
              ],
              "type": "string"
            }
          },
          "required": [
            "expression"
          ],
          "type": "object"
        },
        "name": "calc_eval",
        "outputSchema": {
          "properties": {
            "expression": {
              "description": "The expression that was evaluated",
              "type": "string"
            },
            "mode": {
              "description": "Rendering mode used",
              "type": "string"
            },
            "result": {
              "description": "Rendered result",
              "type": "string"
            }
          },
          "required": [
            "expression",
            "result",
            "mode"
          ],
          "type": "object"
        },
        "title": "Evaluate calc expression"
      },
      {
        "description": "Read or update persistent session configuration",
        "inputSchema": {
          "additionalProperties": false,
          "properties": {
            "action": {
              "description": "'get' returns current config; 'set' updates fields",
              "enum": [
                "get",
                "set"
              ],
              "type": "string"
            },
            "digits": {
              "maximum": 10000,
              "minimum": 1,
              "type": "integer"
            },
            "epsilon": {
              "type": "string"
            },
            "ibase": {
              "description": "Input base (2-36)",
              "maximum": 36,
              "minimum": 2,
              "type": "integer"
            },
            "mode": {
              "enum": [
                "real",
                "frac",
                "int"
              ],
              "type": "string"
            },
            "obase": {
              "description": "Output base (2-36)",
              "maximum": 36,
              "minimum": 2,
              "type": "integer"
            }
          },
          "required": [
            "action"
          ],
          "type": "object"
        },
        "name": "calc_config",
        "outputSchema": {
          "properties": {
            "digits": {
              "type": "integer"
            },
            "epsilon": {
              "type": "string"
            },
            "ibase": {
              "type": "integer"
            },
            "mode": {
              "type": "string"
            },
            "obase": {
              "type": "integer"
            }
          },
          "required": [
            "mode",
            "digits",
            "epsilon",
            "ibase",
            "obase"
          ],
          "type": "object"
        },
        "title": "Get or set session configuration"
      },
      {
        "description": "List available builtin functions, optionally filtered",
        "inputSchema": {
          "additionalProperties": false,
          "properties": {
            "filter": {
              "description": "Optional case-insensitive substring filter",
              "type": "string"
            }
          },
          "type": "object"
        },
        "name": "calc_functions",
        "outputSchema": {
          "properties": {
            "count": {
              "type": "integer"
            },
            "functions": {
              "items": {
                "properties": {
                  "description": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "signature": {
                    "type": "string"
                  }
                },
                "required": [
                  "name",
                  "signature",
                  "description"
                ],
                "type": "object"
              },
              "type": "array"
            }
          },
          "required": [
            "functions",
            "count"
          ],
          "type": "object"
        },
        "title": "List builtin functions"
      },
      {
        "description": "Reset session or get session state",
        "inputSchema": {
          "additionalProperties": false,
          "properties": {
            "action": {
              "description": "'reset' clears all variables and restores defaults; 'state' shows current session info",
              "enum": [
                "reset",
                "state"
              ],
              "type": "string"
            }
          },
          "required": [
            "action"
          ],
          "type": "object"
        },
        "name": "calc_session",
        "outputSchema": {
          "properties": {
            "action": {
              "description": "The action performed",
              "type": "string"
            },
            "epsilon": {
              "type": "string"
            },
            "ibase": {
              "type": "integer"
            },
            "mode": {
              "type": "string"
            },
            "obase": {
              "type": "integer"
            },
            "scopes": {
              "type": "integer"
            },
            "variables": {
              "type": "integer"
            }
          },
          "required": [
            "action"
          ],
          "type": "object"
        },
        "title": "Session control"
      }
    ]
  }
}
